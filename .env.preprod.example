# Copy this to .env.preprod and fill in ONLY ONE of MNEMONIC or SEED per wallet.
# Both wallets must be funded via the Preprod faucet:
#   https://midnight-tmnight-preprod.nethermind.dev/
# Each wallet MUST also have DUST, which you can delegate in 1AM or Lace Carbon (coming soon).

# Set only one per role, delete the other
MIDNIGHT_PREPROD_ALICE_MNEMONIC=replace-with-24-word-mnemonic
MIDNIGHT_PREPROD_ALICE_SEED=replace-with-a-64-char-hex-seed

MIDNIGHT_PREPROD_BOB_MNEMONIC=replace-with-24-word-mnemonic
MIDNIGHT_PREPROD_BOB_SEED=replace-with-a-64-char-hex-seed
